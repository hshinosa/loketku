---
import Layout from '../../layouts/Layout.astro';

const status = Astro.url.searchParams.get('status') || 'form';
---

<Layout title="Tarik Dana - Loketku">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-2xl">

    <!-- Back Link -->
    <a href="/dashboard" class="inline-flex items-center text-sm text-base-content/60 hover:text-base-content mb-6 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
      </svg>
      Kembali ke Dashboard
    </a>

    <!-- ==================== STATE 1: FORM ==================== -->
    {status === 'form' && (
      <div id="withdraw-form-state">
        <div class="bg-base-100 rounded-2xl border border-base-200 shadow-sm overflow-hidden">
          <div class="p-6 border-b border-base-200 bg-gradient-to-r from-primary/5 to-transparent">
            <h1 class="text-2xl font-bold text-base-content">Tarik Dana</h1>
            <p class="text-sm text-base-content/60 mt-1">Tarik saldo dari hasil penjualan tiket ke rekening Anda.</p>
          </div>

          <div class="p-6 space-y-6">
            <!-- Saldo Tersedia -->
            <div class="bg-primary/5 rounded-xl p-4 border border-primary/10">
              <p class="text-sm text-base-content/60">Saldo Tersedia</p>
              <p class="text-2xl font-bold text-primary mt-1" id="saldo-tersedia">Rp 0</p>
            </div>

            <!-- Form -->
            <div class="space-y-4">
              <div class="form-control w-full">
                <label class="label">
                  <span class="label-text font-medium">Jumlah Penarikan</span>
                </label>
                <div class="flex items-center gap-2">
                  <span class="text-base-content/60 font-semibold text-lg">Rp</span>
                  <input id="withdraw-amount" type="text" placeholder="0" class="input input-bordered w-full text-right font-mono text-xl" />
                </div>
                <label class="label">
                  <span id="withdraw-terbilang" class="label-text-alt text-base-content/50 italic"></span>
                </label>
              </div>

              <!-- Info Rekening -->
              <div class="form-control w-full">
                <label class="label">
                  <span class="label-text font-medium">Rekening Tujuan</span>
                </label>
                <div class="bg-base-200 rounded-xl p-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-primary">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
                      </svg>
                    </div>
                    <div>
                      <p class="font-semibold text-base-content" id="bank-display">Belum ada rekening</p>
                      <p class="text-sm text-base-content/60" id="bank-detail">Atur di Pengaturan Profil</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Quick Amount Buttons -->
              <div class="form-control w-full">
                <label class="label">
                  <span class="label-text font-medium">Pilih Nominal Cepat</span>
                </label>
                <div class="grid grid-cols-3 gap-2">
                  <button class="quick-amount btn btn-outline btn-sm" data-amount="500000">Rp 500rb</button>
                  <button class="quick-amount btn btn-outline btn-sm" data-amount="1000000">Rp 1jt</button>
                  <button class="quick-amount btn btn-outline btn-sm" data-amount="5000000">Rp 5jt</button>
                  <button class="quick-amount btn btn-outline btn-sm" data-amount="10000000">Rp 10jt</button>
                  <button class="quick-amount btn btn-outline btn-sm" data-amount="25000000">Rp 25jt</button>
                  <button class="quick-amount btn btn-outline btn-sm" id="btn-max-amount" data-amount="0">Maks</button>
                </div>
              </div>
            </div>

            <!-- Submit -->
            <button id="btn-submit-withdraw" class="btn btn-primary w-full btn-lg" disabled>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              Proses Penarikan
            </button>

            <!-- No Bank Warning -->
            <div id="no-bank-warning" class="alert alert-warning hidden">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
              <div>
                <p class="font-medium">Rekening belum diatur</p>
                <p class="text-sm">Silakan atur rekening di <a href="/settings" class="link link-primary">Pengaturan Profil</a></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- ==================== STATE 2: PROCESSING ==================== -->
    {status === 'processing' && (
      <div id="withdraw-processing-state">
        <div class="bg-base-100 rounded-2xl border border-base-200 shadow-sm overflow-hidden">
          <div class="p-8 text-center">
            <!-- Animated Spinner -->
            <div class="relative w-24 h-24 mx-auto mb-6">
              <div class="absolute inset-0 rounded-full border-4 border-base-200"></div>
              <div class="absolute inset-0 rounded-full border-4 border-primary border-t-transparent animate-spin"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-primary">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </div>
            </div>

            <h2 class="text-xl font-bold text-base-content mb-2">Penarikan Sedang Diproses</h2>
            <p class="text-base-content/60 mb-2">Mohon tunggu, kami sedang memproses penarikan dana Anda.</p>

            <!-- Amount -->
            <div class="bg-base-200 rounded-xl p-4 max-w-xs mx-auto mb-6">
              <p class="text-sm text-base-content/60">Jumlah Penarikan</p>
              <p class="text-xl font-bold text-primary" id="processing-amount">Rp 0</p>
            </div>

            <!-- Refresh Info -->
            <div class="bg-info/10 rounded-xl p-4 max-w-sm mx-auto border border-info/20">
              <div class="flex items-center justify-center gap-2 mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-info animate-spin">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                </svg>
                <p class="text-sm font-medium text-info">Auto-refresh aktif</p>
              </div>
              <p class="text-xs text-base-content/60">Halaman ini akan di-refresh setiap <span class="font-semibold text-info">5 detik</span> untuk menerima status penarikan dana.</p>
              <p class="text-xs text-base-content/50 mt-1">Refresh berikutnya dalam <span id="countdown" class="font-bold text-info">5</span> detik...</p>
            </div>

            <!-- Progress Steps -->
            <div class="mt-8 max-w-xs mx-auto">
              <ul class="steps steps-vertical w-full text-left">
                <li class="step step-primary text-sm">Permintaan diterima</li>
                <li class="step step-primary text-sm">Verifikasi rekening</li>
                <li class="step text-sm text-base-content/50">Transfer dana</li>
                <li class="step text-sm text-base-content/50">Selesai</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- ==================== STATE 3: COMPLETED ==================== -->
    {status === 'completed' && (
      <div id="withdraw-completed-state">
        <div class="bg-base-100 rounded-2xl border border-base-200 shadow-sm overflow-hidden">
          <div class="p-8 text-center">
            <!-- Success Icon -->
            <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-success/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-12 h-12 text-success">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>

            <h2 class="text-xl font-bold text-base-content mb-2">Penarikan Berhasil!</h2>
            <p class="text-base-content/60 mb-6">Dana telah berhasil ditransfer ke rekening Anda.</p>

            <!-- Transaction Summary -->
            <div class="bg-base-200 rounded-xl p-6 max-w-sm mx-auto mb-6 text-left space-y-3">
              <div class="flex justify-between items-center">
                <span class="text-sm text-base-content/60">Jumlah</span>
                <span class="text-lg font-bold text-primary" id="completed-amount">Rp 0</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-base-content/60">Status</span>
                <span class="badge badge-success badge-sm text-white">Berhasil</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-base-content/60">Waktu</span>
                <span class="text-sm font-medium text-base-content" id="completed-time"></span>
              </div>
              <div class="border-t border-base-300 pt-3">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-base-content/60">Rekening</span>
                  <span class="text-sm font-medium text-base-content" id="completed-bank">-</span>
                </div>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-base-content/60">ID Transaksi</span>
                <span class="text-xs font-mono text-base-content/50" id="completed-txid"></span>
              </div>
            </div>

            <!-- Progress Steps Complete -->
            <div class="max-w-xs mx-auto mb-6">
              <ul class="steps steps-vertical w-full text-left">
                <li class="step step-primary text-sm">Permintaan diterima</li>
                <li class="step step-primary text-sm">Verifikasi rekening</li>
                <li class="step step-primary text-sm">Transfer dana</li>
                <li class="step step-primary text-sm">Selesai</li>
              </ul>
            </div>

            <!-- Info -->
            <div class="bg-success/5 rounded-xl p-4 max-w-sm mx-auto mb-6 border border-success/20">
              <p class="text-xs text-base-content/60">Dana akan masuk ke rekening Anda dalam waktu 1x24 jam kerja tergantung bank tujuan.</p>
            </div>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/dashboard" class="btn btn-primary">Kembali ke Dashboard</a>
              <a href="/dashboard/withdraw" class="btn btn-outline">Tarik Dana Lagi</a>
            </div>
          </div>
        </div>
      </div>
    )}

  </div>

  <script>
    const currentStatus = new URLSearchParams(window.location.search).get('status') || 'form';

    // ---- Load bank info from localStorage ----
    function getBankInfo() {
      try {
        const userStr = localStorage.getItem('loketku_user');
        if (userStr) {
          const user = JSON.parse(userStr);
          return {
            bankName: user.bankName || '',
            bankAccount: user.bankAccount || '',
            bankAccountName: user.bankAccountName || user.name || '',
            hasBank: !!(user.bankName && user.bankAccount),
          };
        }
      } catch {}
      return { bankName: '', bankAccount: '', bankAccountName: '', hasBank: false };
    }

    // ---- Format Rupiah ----
    function formatRupiah(n: number) {
      return 'Rp ' + new Intl.NumberFormat('id-ID').format(n);
    }

    // ---- STATE: FORM ----
    if (currentStatus === 'form') {
      const amountInput = document.getElementById('withdraw-amount') as HTMLInputElement;
      const terbilang = document.getElementById('withdraw-terbilang');
      const submitBtn = document.getElementById('btn-submit-withdraw');
      const bankDisplay = document.getElementById('bank-display');
      const bankDetail = document.getElementById('bank-detail');
      const noBankWarning = document.getElementById('no-bank-warning');
      const maxBtn = document.getElementById('btn-max-amount');

      const bank = getBankInfo();

      // Show bank info
      if (bank.hasBank) {
        if (bankDisplay) bankDisplay.textContent = `${bank.bankName} - ${bank.bankAccount}`;
        if (bankDetail) bankDetail.textContent = `a.n. ${bank.bankAccountName}`;
      } else {
        if (noBankWarning) noBankWarning.classList.remove('hidden');
      }

      // Get saldo from transactions (mock)
      const saldo = 15750000; // mock value
      const saldoEl = document.getElementById('saldo-tersedia');
      if (saldoEl) saldoEl.textContent = formatRupiah(saldo);

      // Set max amount
      if (maxBtn) maxBtn.setAttribute('data-amount', String(saldo));

      // Format input
      if (amountInput) {
        amountInput.addEventListener('input', () => {
          const raw = amountInput.value.replace(/\D/g, '');
          const formatted = new Intl.NumberFormat('id-ID').format(Number(raw));
          amountInput.value = raw ? formatted : '';

          if (terbilang) {
            const num = Number(raw);
            if (num >= 1000000) {
              terbilang.textContent = `${(num / 1000000).toFixed(1).replace('.0', '')} juta`;
            } else if (num >= 1000) {
              terbilang.textContent = `${(num / 1000).toFixed(0)} ribu`;
            } else {
              terbilang.textContent = '';
            }
          }

          // Enable/disable submit
          const num = Number(raw);
          if (submitBtn) {
            submitBtn.disabled = !(num > 0 && num <= saldo && bank.hasBank);
          }
        });
      }

      // Quick amount buttons
      document.querySelectorAll('.quick-amount').forEach(btn => {
        btn.addEventListener('click', () => {
          const amount = Number((btn as HTMLElement).getAttribute('data-amount'));
          if (amountInput) {
            const raw = String(amount);
            amountInput.value = new Intl.NumberFormat('id-ID').format(amount);
            amountInput.dispatchEvent(new Event('input'));
          }
        });
      });

      // Submit
      if (submitBtn) {
        submitBtn.addEventListener('click', () => {
          const raw = amountInput.value.replace(/\D/g, '');
          const amount = Number(raw);
          if (amount > 0 && bank.hasBank) {
            sessionStorage.setItem('withdraw_amount', raw);
            sessionStorage.setItem('withdraw_bank', JSON.stringify(bank));
            sessionStorage.setItem('withdraw_time', new Date().toISOString());
            window.location.href = '/dashboard/withdraw?status=processing';
          }
        });
      }
    }

    // ---- STATE: PROCESSING ----
    if (currentStatus === 'processing') {
      const processingAmount = document.getElementById('processing-amount');
      const countdownEl = document.getElementById('countdown');
      const amount = sessionStorage.getItem('withdraw_amount') || '0';

      if (processingAmount) {
        processingAmount.textContent = formatRupiah(Number(amount));
      }

      // Countdown and redirect
      let seconds = 5;
      if (countdownEl) countdownEl.textContent = String(seconds);

      const interval = setInterval(() => {
        seconds--;
        if (countdownEl) countdownEl.textContent = String(seconds);
        if (seconds <= 0) {
          clearInterval(interval);
          window.location.href = '/dashboard/withdraw?status=completed';
        }
      }, 1000);
    }

    // ---- STATE: COMPLETED ----
    if (currentStatus === 'completed') {
      const completedAmount = document.getElementById('completed-amount');
      const completedTime = document.getElementById('completed-time');
      const completedBank = document.getElementById('completed-bank');
      const completedTxId = document.getElementById('completed-txid');

      const amount = sessionStorage.getItem('withdraw_amount') || '0';
      const bankStr = sessionStorage.getItem('withdraw_bank');
      const timeStr = sessionStorage.getItem('withdraw_time');

      if (completedAmount) completedAmount.textContent = formatRupiah(Number(amount));

      if (bankStr) {
        try {
          const bank = JSON.parse(bankStr);
          if (completedBank) completedBank.textContent = `${bank.bankName} - ${bank.bankAccount}`;
        } catch {}
      }

      if (timeStr) {
        const d = new Date(timeStr);
        if (completedTime) completedTime.textContent = d.toLocaleString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
      }

      // Generate mock transaction ID
      if (completedTxId) {
        completedTxId.textContent = 'WD-' + Date.now().toString(36).toUpperCase();
      }
    }
  </script>
</Layout>
