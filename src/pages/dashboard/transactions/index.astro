---
import Layout from '../../../layouts/Layout.astro';
import { db } from '../../../lib/db';
import { transactions } from '../../../lib/schema';

const rows = await db.select().from(transactions);

const formatCurrency = (amount: number) =>
  new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(amount);

const formatDate = (dateString: string) =>
  new Intl.DateTimeFormat('id-ID', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(new Date(dateString));

const getStatusProps = (status: string) => {
  switch (status) {
    case 'paid':
      return { class: 'badge bg-success/10 text-success border-success/20 badge-sm font-medium', text: 'Berhasil' };
    case 'pending':
      return { class: 'badge bg-warning/10 text-warning border-warning/20 badge-sm font-medium', text: 'Menunggu' };
    case 'cancelled':
      return { class: 'badge bg-error/10 text-error border-error/20 badge-sm font-medium', text: 'Gagal' };
    default:
      return { class: 'badge badge-ghost badge-sm', text: status };
  }
};

const transactionsList = rows.map((t) => ({
  id: t.id,
  buyerName: t.buyerName,
  event: t.eventTitle,
  category: t.ticketType,
  quantity: t.quantity,
  totalAmount: t.total,
  status: t.status,
  date: t.timestamp,
}));

const totalRevenue = transactionsList
  .filter((t) => t.status === 'paid')
  .reduce((sum, t) => sum + t.totalAmount, 0);
const totalTicketsSold = transactionsList
  .filter((t) => t.status === 'paid')
  .reduce((sum, t) => sum + t.quantity, 0);
const successCount = transactionsList.filter((t) => t.status === 'paid').length;
---

<Layout title="Transaksi | Loketku">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
      <div>
        <div class="text-sm breadcrumbs text-base-content/60 mb-2">
          <ul>
            <li><a href="/dashboard">Dashboard</a></li>
            <li class="text-base-content font-medium">Transaksi</li>
          </ul>
        </div>
        <h1 class="text-3xl font-bold text-base-content">Daftar Transaksi</h1>
        <p class="text-base-content/60 mt-1">Pantau semua transaksi penjualan tiket event Anda.</p>
      </div>
      
      <div class="flex gap-2 w-full md:w-auto">
        <button class="btn btn-outline text-primary hover:bg-primary hover:text-primary-content hover:border-primary btn-sm flex-1 md:flex-none">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Export CSV
        </button>
      </div>
    </div>

    {/* Filters */}
    <div class="bg-base-100 p-4 rounded-xl shadow-sm border border-base-200 mb-6 flex flex-col md:flex-row gap-4">
      <div class="form-control w-full md:max-w-xs">
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-base-content/40">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </div>
          <input type="text" placeholder="Cari ID Transaksi atau Nama..." class="input input-bordered w-full pl-10 input-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
      
      <select class="select select-bordered select-sm w-full md:max-w-xs focus:outline-none focus:border-primary">
        <option disabled>Semua Event</option>
        <option>Seminar Nasional Teknologi 2026</option>
        <option>Workshop UI/UX Design</option>
        <option>Konser Musik Kampus</option>
      </select>
      
      <select class="select select-bordered select-sm w-full md:max-w-xs focus:outline-none focus:border-primary">
        <option disabled>Status Transaksi</option>
        <option>Berhasil</option>
        <option>Menunggu</option>
        <option>Gagal</option>
      </select>
    </div>

    {/* Summary Cards */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-base-100 p-6 rounded-xl shadow-sm border border-base-200 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
        <div class="text-sm font-medium text-base-content/60 mb-1 relative z-10">Total Pendapatan</div>
        <div class="text-2xl font-bold text-base-content relative z-10">{formatCurrency(totalRevenue)}</div>
        <div class="text-xs text-success mt-2 flex items-center relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 mr-1">
            <path fill-rule="evenodd" d="M10 17a.75.75 0 0 1-.75-.75V5.612L5.29 9.77a.75.75 0 0 1-1.08-1.04l5.25-5.5a.75.75 0 0 1 1.08 0l5.25 5.5a.75.75 0 1 1-1.08 1.04l-3.96-4.158V16.25A.75.75 0 0 1 10 17Z" clip-rule="evenodd" />
          </svg>
          12% dari bulan lalu
        </div>
      </div>
      <div class="bg-base-100 p-6 rounded-xl shadow-sm border border-base-200 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
        <div class="text-sm font-medium text-base-content/60 mb-1 relative z-10">Tiket Terjual</div>
        <div class="text-2xl font-bold text-base-content relative z-10">{totalTicketsSold} Tiket</div>
        <div class="text-xs text-success mt-2 flex items-center relative z-10">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3 mr-1">
            <path fill-rule="evenodd" d="M10 17a.75.75 0 0 1-.75-.75V5.612L5.29 9.77a.75.75 0 0 1-1.08-1.04l5.25-5.5a.75.75 0 0 1 1.08 0l5.25 5.5a.75.75 0 1 1-1.08 1.04l-3.96-4.158V16.25A.75.75 0 0 1 10 17Z" clip-rule="evenodd" />
          </svg>
          5% dari bulan lalu
        </div>
      </div>
      <div class="bg-base-100 p-6 rounded-xl shadow-sm border border-base-200 relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
        <div class="text-sm font-medium text-base-content/60 mb-1 relative z-10">Transaksi Berhasil</div>
        <div class="text-2xl font-bold text-base-content relative z-10">{successCount} Transaksi</div>
        <div class="text-xs text-base-content/60 mt-2 relative z-10">Dari total {transactionsList.length} transaksi</div>
      </div>
    </div>

    {/* Transactions Table */}
    <div class="bg-base-100 rounded-xl shadow-sm border border-base-200 overflow-hidden">
      {transactionsList.length > 0 ? (
      <>
      <div class="overflow-x-auto">
        <table class="table w-full">
          <thead>
            <tr class="bg-base-200 text-base-content/70 border-b border-base-200">
              <th class="font-semibold">ID Transaksi</th>
              <th class="font-semibold">Tanggal</th>
              <th class="font-semibold">Pembeli</th>
              <th class="font-semibold">Event & Kategori</th>
              <th class="text-center font-semibold">Jumlah</th>
              <th class="text-right font-semibold">Total</th>
              <th class="text-center font-semibold">Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-base-200">
            {transactionsList.map((trx) => (
              <tr class="hover:bg-base-200/50 transition-colors">
                <td class="font-medium text-base-content">{trx.id}</td>
                <td class="text-base-content/60 text-sm">{formatDate(trx.date)}</td>
                <td>
                  <div class="font-medium text-base-content">{trx.buyerName}</div>
                </td>
                <td>
                  <div class="text-sm font-medium text-base-content">{trx.event}</div>
                  <div class="text-xs text-base-content/60 mt-0.5">{trx.category}</div>
                </td>
                <td class="text-center">
                  <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-base-200 text-xs font-medium text-base-content/70">
                    {trx.quantity}
                  </span>
                </td>
                <td class="text-right font-medium text-base-content">{formatCurrency(trx.totalAmount)}</td>
                <td class="text-center">
                  <span class={getStatusProps(trx.status).class}>{getStatusProps(trx.status).text}</span>
                </td>
                <td>
                  <button class="btn btn-ghost btn-xs text-primary hover:bg-primary/10">Detail</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      
      {/* Pagination */}
      <div class="p-4 border-t border-base-200 flex items-center justify-between bg-base-200/50">
        <div class="text-sm text-base-content/60">
          Menampilkan <span class="font-medium text-base-content">1</span> sampai <span class="font-medium text-base-content">5</span> dari <span class="font-medium text-base-content">5</span> transaksi
        </div>
        <div class="join">
          <button class="join-item btn btn-sm btn-disabled bg-base-100 border-base-300">«</button>
          <button class="join-item btn btn-sm bg-primary text-white border-none hover:bg-primary/90">1</button>
          <button class="join-item btn btn-sm btn-disabled bg-base-100 border-base-300">»</button>
        </div>
      </div>
      </>
      ) : (
      <!-- Empty State -->
      <div class="text-center py-20">
        <div class="w-24 h-24 bg-base-300 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-base-content/40">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-base-content">Belum ada transaksi</h3>
        <p class="text-base-content/60 mt-2">Transaksi akan muncul di sini setelah ada pembeli yang melakukan pemesanan tiket.</p>
      </div>
      )}
    </div>
  </div>
</Layout>