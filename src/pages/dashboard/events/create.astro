---
import Layout from '../../../layouts/Layout.astro';
import CreateEventForm from '../../../components/dashboard/CreateEventForm';
---

<Layout title="Buat Event Baru | Loketku">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <div class="mb-8">
      <div class="text-sm breadcrumbs text-gray-500 mb-4">
        <ul>
          <li><a href="/dashboard">Dashboard</a></li>
          <li><a href="/dashboard/events">Event</a></li>
          <li class="text-gray-900 font-medium">Buat Baru</li>
        </ul>
      </div>
      <h1 class="text-3xl font-bold text-gray-900">Buat Event Baru</h1>
      <p class="text-gray-500 mt-2">Lengkapi detail event Anda untuk mulai menjual tiket.</p>
    </div>

    <CreateEventForm client:load />
  </div>
</Layout>
