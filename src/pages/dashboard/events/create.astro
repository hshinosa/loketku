---
import Layout from '../../../layouts/Layout.astro';
import CreateEventForm from '../../../components/dashboard/CreateEventForm';
---

<Layout title="Buat Event Baru | Loketku">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-3xl">
    <div class="mb-6">
      <div class="text-sm breadcrumbs text-base-content/50 mb-2">
        <ul>
          <li><a href="/dashboard">Dashboard</a></li>
          <li><a href="/dashboard/events">Event</a></li>
          <li class="text-base-content font-medium">Buat Baru</li>
        </ul>
      </div>
      <h1 class="text-2xl font-bold text-base-content">Buat Event Baru</h1>
      <p class="text-sm text-base-content/50 mt-1">Ikuti langkah-langkah berikut untuk mempublikasikan event Anda.</p>
    </div>

    <CreateEventForm client:load />
  </div>
</Layout>
