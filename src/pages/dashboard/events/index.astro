---
import Layout from '../../../layouts/Layout.astro';
import { db, initDb } from '../../../lib/db';
import { events } from '../../../lib/schema';

await initDb();
const rows = await db.select().from(events);

const formatRupiah = (n: number) =>
  new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(n);

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });

const formatTime = (iso: string) =>
  new Date(iso).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

const eventsList = rows.map((e) => {
  const sold = e.sold;
  const quota = e.quota;
  const ratio = quota > 0 ? sold / quota : 0;
  const status = ratio >= 1 ? 'Selesai' : sold > 0 ? 'Aktif' : 'Draft';
  return {
    id: e.id,
    title: e.title,
    date: formatDate(e.date),
    time: `${formatTime(e.date)} WIB`,
    location: e.location,
    status,
    ticketsSold: sold,
    quota,
    revenue: formatRupiah(sold * e.price),
    image: e.poster,
  };
});
---

<Layout title="Kelola Event - Loketku">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
      <div>
        <h1 class="text-3xl font-bold text-base-content">Kelola Event</h1>
        <p class="text-base-content/60 mt-1">Daftar semua event yang Anda buat</p>
      </div>
      <div class="flex gap-3">
        <a href="/dashboard" class="btn btn-ghost">Kembali ke Dashboard</a>
        <a href="/dashboard/events/create" class="btn bg-primary hover:bg-primary/90 text-white border-none">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mr-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Buat Event Baru
        </a>
      </div>
    </div>

    <!-- Filters and Search -->
    <div class="bg-base-100 p-4 rounded-xl shadow-sm border border-base-200 mb-8 flex flex-col md:flex-row gap-4 justify-between items-center">
      <div class="flex gap-2 w-full md:w-auto overflow-x-auto pb-2 md:pb-0">
        <button class="btn btn-sm bg-primary text-white hover:bg-primary/90 border-none">Semua Event</button>
        <button class="btn btn-sm btn-ghost">Aktif</button>
        <button class="btn btn-sm btn-ghost">Draft</button>
        <button class="btn btn-sm btn-ghost">Selesai</button>
      </div>
      <div class="join w-full md:w-auto">
        <input type="text" placeholder="Cari nama event..." class="input input-bordered input-sm join-item w-full md:w-64 focus:outline-none focus:border-primary" />
        <button class="btn btn-sm btn-square join-item bg-primary text-white hover:bg-primary/90 border-none">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Event Grid -->
    {eventsList.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {eventsList.map((event) => (
        <div class="card bg-base-100 shadow-sm border border-base-200 overflow-hidden hover:shadow-md transition-shadow group">
          <figure class="h-48 relative overflow-hidden">
            <img src={event.image} alt={event.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            <div class="absolute top-3 right-3">
              <span class={`badge ${
                event.status === 'Aktif' ? 'bg-primary border-none' : 
                event.status === 'Draft' ? 'badge-warning' : 
                'badge-neutral'
              } text-white font-medium shadow-sm`}>
                {event.status}
              </span>
            </div>
          </figure>
          <div class="card-body p-5">
            <h2 class="card-title text-lg font-bold text-base-content line-clamp-2 leading-tight" title={event.title}>
              {event.title}
            </h2>
            
            <div class="space-y-2 mt-3 text-sm text-base-content/70">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-primary">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
                <span>{event.date} • {event.time}</span>
              </div>
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-primary">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                <span class="truncate">{event.location}</span>
              </div>
            </div>

            <div class="divider my-2"></div>

            <div class="grid grid-cols-2 gap-4 mb-4">
              <div>
                <p class="text-xs text-base-content/60 mb-1">Tiket Terjual</p>
                <p class="text-sm font-bold text-base-content">
                  {event.ticketsSold} <span class="text-base-content/40 font-normal">/ {event.quota}</span>
                </p>
                <div class="w-full bg-base-200 rounded-full h-1.5 mt-1.5">
                  <div 
                    class={`h-1.5 rounded-full ${
                      (event.ticketsSold / event.quota) >= 0.9 ? 'bg-error' : 
                      (event.ticketsSold / event.quota) >= 0.5 ? 'bg-warning' : 
                      'bg-primary'
                    }`} 
                    style={`width: ${(event.ticketsSold / event.quota) * 100}%`}
                  ></div>
                </div>
              </div>
              <div>
                <p class="text-xs text-base-content/60 mb-1">Pendapatan</p>
                <p class="text-sm font-bold text-base-content">{event.revenue}</p>
              </div>
            </div>

            <div class="card-actions justify-end mt-auto pt-2">
              <a href={`/dashboard/events/edit/${event.id}`} class="btn btn-sm btn-outline text-primary hover:bg-primary hover:text-white hover:border-primary flex-1">Edit</a>
              <button class="btn btn-sm btn-outline text-error hover:bg-error hover:text-white hover:border-error flex-1 btn-delete" data-id={event.id} data-title={event.title}>Hapus</button>
            </div>
          </div>
        </div>
      ))}
    </div>
    ) : (
    <!-- Empty State -->
    <div class="text-center py-20">
      <div class="w-24 h-24 bg-base-300 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-base-content/40">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
      </div>
      <h3 class="text-lg font-bold text-base-content">Belum ada event</h3>
      <p class="text-base-content/60 mt-2 mb-6">Anda belum membuat event apapun. Mulai buat event pertama Anda!</p>
      <a href="/dashboard/events/create" class="btn bg-primary hover:bg-primary/90 text-white border-none">Buat Event Baru</a>
    </div>
    )}
  </div>

  <!-- Delete Confirmation Modal -->
  <dialog id="delete-modal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Hapus Event?</h3>
      <p class="py-4">Event <strong id="delete-event-title"></strong> akan dihapus permanen beserta semua transaksi terkait. Aksi ini tidak bisa dibatalkan.</p>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn btn-ghost">Batal</button>
        </form>
        <button id="confirm-delete" class="btn btn-error text-white">Ya, Hapus</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const modal = document.getElementById('delete-modal') as HTMLDialogElement;
      const titleEl = document.getElementById('delete-event-title');
      const confirmBtn = document.getElementById('confirm-delete');
      let deleteTargetId = '';

      document.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', () => {
          deleteTargetId = (btn as HTMLElement).dataset.id ?? '';
          if (titleEl) titleEl.textContent = (btn as HTMLElement).dataset.title ?? '';
          modal?.showModal();
        });
      });

      confirmBtn?.addEventListener('click', async () => {
        if (!deleteTargetId) return;
        confirmBtn.classList.add('loading');
        try {
          const res = await fetch(`/api/events/${deleteTargetId}`, { method: 'DELETE' });
          const data = await res.json();
          if (res.ok && data.ok) {
            window.location.reload();
          }
        } catch (err) {
          console.error('Delete failed:', err);
        }
      });
    });
  </script>
</Layout>