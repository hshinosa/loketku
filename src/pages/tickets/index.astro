---
import Layout from '../../layouts/Layout.astro';
import { db, initDb } from '../../lib/db';
import { tickets, events } from '../../lib/schema';
import { eq } from 'drizzle-orm';

await initDb();
const rows = await db.select().from(tickets).leftJoin(events, eq(tickets.eventId, events.id));

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' });

const formatTime = (iso: string) =>
  new Date(iso).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

const myTickets = rows.map((row) => {
  const t = row.tickets;
  const e = row.events;
  return {
    id: t.id,
    eventTitle: t.eventTitle,
    date: formatDate(t.date),
    time: formatTime(t.date),
    location: e?.location ?? '-',
    type: t.ticketType,
    status: t.status,
    image: e?.poster ?? 'https://placehold.co/600x400/1932B9/FFFFFF?text=Tiket',
  };
});

const activeCount = myTickets.filter((t) => t.status === 'valid').length;
const historyCount = myTickets.length - activeCount;
---

<Layout title="Tiket Saya - Loketku">
  <div class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      
      <!-- Header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold text-base-content">Tiket Saya</h1>
          <p class="text-base-content/70 mt-1">Kelola semua tiket acara Anda di sini</p>
        </div>
        <a href="/" class="btn btn-outline btn-sm">Cari Acara Lain</a>
      </div>

      <!-- Tabs -->
      <div role="tablist" class="tabs tabs-boxed mb-6 bg-base-100 p-1">
        <button role="tab" class="tab tab-active font-medium" data-filter="active">Tiket Aktif ({activeCount})</button>
        <button role="tab" class="tab font-medium" data-filter="history">Riwayat ({historyCount})</button>
      </div>

      <!-- Ticket List -->
      <div id="ticket-list" class="space-y-4">
        {myTickets.map((ticket) => (
          <a href={`/ticket/${ticket.id}`} class="block group ticket-card" data-status={ticket.status}>
            <div class={`card sm:card-side bg-base-100 shadow-sm hover:shadow-md transition-all border border-base-200 overflow-hidden ${ticket.status === 'used' ? 'opacity-75 grayscale-[30%]' : ''}`}>
              
              <!-- Event Image -->
              <figure class="sm:w-48 h-32 sm:h-auto relative">
                <img src={ticket.image} alt={ticket.eventTitle} class="w-full h-full object-cover" />
                {ticket.status === 'used' && (
                  <div class="absolute inset-0 bg-base-300/60 flex items-center justify-center backdrop-blur-[2px]">
                    <span class="badge badge-neutral font-bold">TELAH DIGUNAKAN</span>
                  </div>
                )}
              </figure>
              
              <!-- Ticket Info -->
              <div class="card-body p-5 sm:p-6">
                <div class="flex justify-between items-start gap-4">
                  <div>
                    <div class="flex items-center gap-2 mb-1">
                      <span class={`badge badge-sm ${ticket.status === 'valid' ? 'badge-success text-success-content' : 'badge-neutral'}`}>
                        {ticket.status === 'valid' ? 'Valid' : 'Selesai'}
                      </span>
                      <span class="text-xs font-mono text-base-content/50">{ticket.id}</span>
                    </div>
                    <h2 class="card-title text-lg group-hover:text-primary transition-colors">{ticket.eventTitle}</h2>
                  </div>
                  
                  <!-- Date Badge -->
                  <div class="bg-base-200 rounded-lg p-2 text-center min-w-[60px] shrink-0">
                    <div class="text-xs font-semibold text-secondary uppercase">{ticket.date.split(' ')[1]}</div>
                    <div class="text-xl font-bold leading-none my-0.5">{ticket.date.split(' ')[0]}</div>
                  </div>
                </div>

                <div class="mt-4 grid grid-cols-2 gap-y-2 gap-x-4 text-sm text-base-content/70">
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="truncate">{ticket.time}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    <span class="truncate">{ticket.location}</span>
                  </div>
                  <div class="flex items-center gap-2 col-span-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z" />
                    </svg>
                    <span class="font-medium text-base-content">{ticket.type}</span>
                  </div>
                </div>
                
                <div class="mt-4 flex justify-end sm:hidden">
                  <span class="text-primary text-sm font-medium flex items-center gap-1">
                    Lihat E-Ticket
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Empty State -->
      {myTickets.length === 0 && (
      <div class="text-center py-16">
        <div class="w-24 h-24 bg-base-300 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-base-content/40">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-base-content">Belum ada tiket</h3>
        <p class="text-base-content/60 mt-2 mb-6">Anda belum memiliki tiket acara apapun saat ini.</p>
        <a href="/" class="btn btn-primary">Cari Acara Sekarang</a>
      </div>
      )}

    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('[role="tab"]');
    const cards = document.querySelectorAll('.ticket-card');
    
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('tab-active'));
        tab.classList.add('tab-active');
        
        const filter = (tab as HTMLElement).dataset.filter;
        cards.forEach(card => {
          const status = (card as HTMLElement).dataset.status;
          if (filter === 'active') {
            (card as HTMLElement).style.display = status === 'valid' ? '' : 'none';
          } else {
            (card as HTMLElement).style.display = status !== 'valid' ? '' : 'none';
          }
        });
      });
    });
  });
</script>