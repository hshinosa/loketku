---
import Layout from '../../layouts/Layout.astro';
import { db, initDb } from '../../lib/db';
import { transactions } from '../../lib/schema';
import { eq } from 'drizzle-orm';

export const prerender = false;

const { id } = Astro.params;

await initDb();
const rows = await db.select().from(transactions).where(eq(transactions.id, id ?? ''));
const trx = rows[0];

if (!trx) {
  return Astro.redirect('/');
}

const formatRupiah = (n: number) =>
  new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(n);
---

<Layout title={`Pembayaran - ${trx.id}`}>
  <div class="min-h-screen bg-base-200 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-base-content">Pembayaran</h1>
        <p class="text-base-content/70 mt-2">Selesaikan pembayaran Anda</p>
      </div>

      <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
          <div class="flex justify-between items-center mb-6">
            <span class="text-sm font-medium text-base-content/70">Order ID</span>
            <span class="font-mono font-bold text-primary">{trx.id}</span>
          </div>

          <div class="divider my-0"></div>

          <div class="py-6 text-center">
            <p class="text-sm font-medium text-base-content/70 mb-2">Total Pembayaran</p>
            <h2 class="text-4xl font-bold text-base-content">{formatRupiah(trx.total)}</h2>
            <p class="text-xs text-base-content/60 mt-2">{trx.eventTitle} • {trx.quantity} tiket</p>
          </div>

          <div class="divider my-0"></div>

          <div class="mt-6">
            <h3 class="text-sm font-medium text-base-content/70 mb-4">Metode Pembayaran (Simulasi)</h3>
            <div class="space-y-3">
              <label class="label cursor-pointer border border-base-300 rounded-lg p-4 hover:bg-base-200 transition-colors">
                <span class="label-text font-medium flex items-center gap-3">
                  <div class="w-8 h-8 bg-blue-100 text-blue-600 rounded flex items-center justify-center font-bold text-xs">BCA</div>
                  BCA Virtual Account
                </span>
                <input type="radio" name="payment_method" class="radio radio-primary" checked />
              </label>
              <label class="label cursor-pointer border border-base-300 rounded-lg p-4 hover:bg-base-200 transition-colors">
                <span class="label-text font-medium flex items-center gap-3">
                  <div class="w-8 h-8 bg-green-100 text-green-600 rounded flex items-center justify-center font-bold text-xs">QRS</div>
                  QRIS
                </span>
                <input type="radio" name="payment_method" class="radio radio-primary" />
              </label>
            </div>
          </div>

          <div class="card-actions mt-8 flex-col gap-3">
            <div id="payment-error" class="alert alert-error hidden w-full">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span id="payment-error-msg"></span>
            </div>
            <button id="btn-simulate-success" class="btn btn-primary w-full" data-ticket-id={trx.ticketId ?? ''}>
              {trx.status === 'paid' ? 'Lanjut ke E-Ticket' : 'Simulasikan Bayar Sukses'}
            </button>
            <button id="btn-cancel" class="btn btn-ghost w-full">
              Batalkan Pembayaran
            </button>
          </div>
        </div>
      </div>

      <div class="mt-8 text-center flex items-center justify-center gap-2 text-sm text-base-content/60">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
        Pembayaran Aman & Terenkripsi
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btnSuccess = document.getElementById('btn-simulate-success') as HTMLButtonElement | null;
    const btnCancel = document.getElementById('btn-cancel');
    const pathParts = window.location.pathname.split('/');
    const transactionId = pathParts[pathParts.length - 1];

    if (btnSuccess) {
      btnSuccess.addEventListener('click', async () => {
        btnSuccess.classList.add('loading');
        btnSuccess.innerHTML = '<span class="loading loading-spinner"></span> Memproses...';

        try {
          const res = await fetch('/api/transactions/pay', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ transactionId }),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) {
            const errEl = document.getElementById('payment-error');
            const errMsg = document.getElementById('payment-error-msg');
            if (errEl && errMsg) {
              errMsg.textContent = data.error ?? 'Gagal memproses pembayaran';
              errEl.classList.remove('hidden');
            }
            btnSuccess.classList.remove('loading');
            btnSuccess.innerHTML = 'Simulasikan Bayar Sukses';
            return;
          }
          const ticketId = btnSuccess.dataset.ticketId;
          if (ticketId) {
            window.location.href = `/ticket/${ticketId}`;
          } else {
            window.location.href = '/';
          }
        } catch (err) {
          const errEl = document.getElementById('payment-error');
          const errMsg = document.getElementById('payment-error-msg');
          if (errEl && errMsg) {
            errMsg.textContent = 'Gagal terhubung ke server: ' + String(err);
            errEl.classList.remove('hidden');
          }
          btnSuccess.classList.remove('loading');
          btnSuccess.innerHTML = 'Simulasikan Bayar Sukses';
        }
      });
    }

    if (btnCancel) {
      btnCancel.addEventListener('click', () => {
        if (confirm('Apakah Anda yakin ingin membatalkan pembayaran ini?')) {
          window.location.href = '/';
        }
      });
    }
  });
</script>