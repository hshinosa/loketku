---
import Layout from '../../layouts/Layout.astro';
import CheckoutForm from '../../components/dashboard/CheckoutForm';
import { db, initDb } from '../../lib/db';
import { events } from '../../lib/schema';
import { eq } from 'drizzle-orm';

const { id } = Astro.params;

await initDb();

// Read quantity from URL search params (e.g. ?quantity=2)
const url = new URL(Astro.request.url);
const quantity = Math.max(1, Math.min(10, parseInt(url.searchParams.get('quantity') ?? '1', 10) || 1));

// [id] is an event ID — fetch event directly
const event = await db
  .select()
  .from(events)
  .where(eq(events.id, id as string))
  .get();

if (!event) {
  return Astro.redirect('/');
}

const remaining = event.quota - event.sold;
const unitPrice = event.price;
const subtotal = unitPrice * quantity;
const adminFee = 2500;
const total = subtotal + adminFee;

const formattedDate = new Date(event.date).toLocaleDateString('id-ID', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const formatCurrency = (amount: number) => {
  return new Intl.NumberFormat('id-ID', {
    style: 'currency',
    currency: 'IDR',
    minimumFractionDigits: 0,
  }).format(amount);
};
---

<Layout title={`Checkout - ${event.title}`}>
  <div class="bg-gray-50 min-h-screen py-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      
      <div class="mb-8">
        <a href={`/event/${event.id}`} class="text-primary hover:underline flex items-center gap-2 w-fit">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Kembali ke Event
        </a>
        <h1 class="text-3xl font-bold text-gray-900 mt-4">Checkout Tiket</h1>
      </div>

      <div class="flex flex-col lg:flex-row gap-8">
        
        {/* Left Column: Form */}
        <div class="lg:w-2/3">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8 mb-6">
            <h2 class="text-xl font-bold text-gray-900 mb-6">Informasi Pembeli</h2>
            
            <CheckoutForm
              client:load
              ticketId={event.id}
              eventId={event.id}
              quantity={quantity}
              totalAmount={total}
            />
            
          </div>
        </div>

        {/* Right Column: Order Summary */}
        <div class="lg:w-1/3">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sticky top-24">
            <h2 class="text-xl font-bold text-gray-900 mb-4">Ringkasan Pesanan</h2>
            
              <div class="flex gap-4 mb-6">
              <img src={event.poster} alt={event.title} class="w-20 h-20 object-cover rounded-lg" />
              <div>
                <h3 class="font-semibold text-base-content line-clamp-2">{event.title}</h3>
                <p class="text-sm text-base-content/60 mt-1">{formattedDate}</p>
              </div>
            </div>

            <div class="divider my-2"></div>

            <div class="space-y-3 my-4">
              <div class="flex justify-between text-sm">
                <span class="text-base-content/60">Tiket Regular (x{quantity})</span>
                <span class="font-medium text-base-content">{formatCurrency(subtotal)}</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-base-content/60">Biaya Admin</span>
                <span class="font-medium text-base-content">{formatCurrency(adminFee)}</span>
              </div>
            </div>

            <div class="divider my-2"></div>

            <div class="flex justify-between items-center mb-6">
              <span class="font-bold text-base-content">Total Pembayaran</span>
              <span class="text-xl font-bold text-primary">{formatCurrency(total)}</span>
            </div>

            <div class="bg-blue-50 text-blue-800 p-4 rounded-lg text-sm flex gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p>E-ticket akan dikirimkan ke email dan WhatsApp Anda setelah pembayaran berhasil.</p>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</Layout>
