---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/dashboard/EventCard';
import { db } from '../lib/db';
import { events } from '../lib/schema';
import { seed } from '../lib/seed';

const existing = await db.select().from(events).limit(1);
if (existing.length === 0) {
  await seed();
}

const rows = await db.select().from(events);
const mockEvents = rows.map((e) => ({
  id: e.id,
  title: e.title,
  date: e.date,
  location: e.location,
  imageUrl: e.poster,
  price: e.price,
}));
---

<Layout title="Loketku - Platform Ticketing Event Kampus & Komunitas">
  {/* Events Section */}
  <section class="pt-8 pb-12 bg-base-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-8">
        <div>
          <h1 class="text-3xl font-bold text-base-content mb-1">Event Terpopuler</h1>
          <p class="text-base-content/60">Temukan dan beli tiket event favoritmu</p>
        </div>
        <div class="join w-full sm:w-auto sm:max-w-xs">
          <input type="text" placeholder="Cari event..." class="input input-bordered input-sm join-item flex-1" />
          <button class="btn btn-primary btn-sm join-item">Cari</button>
        </div>
      </div>

      {mockEvents.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {mockEvents.map((event) => (
            <EventCard 
              id={event.id}
              title={event.title}
              date={event.date}
              location={event.location}
              imageUrl={event.imageUrl}
              price={event.price}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-base-content/50 text-lg">Belum ada event tersedia.</p>
        </div>
      )}
    </div>
  </section>

  {/* CTA - Compact */}
  <section class="py-10 bg-base-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-base-content mb-2">Mau bikin event sendiri?</h2>
      <p class="text-base-content/60 mb-4">Gratis, langsung bisa jualan tiket dalam hitungan menit.</p>
      <a href="/login" class="btn btn-primary">Buat Event Sekarang</a>
    </div>
  </section>
</Layout>
