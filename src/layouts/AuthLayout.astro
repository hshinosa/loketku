---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Masuk ke Loketku" } = Astro.props;
---

<!doctype html>
<html lang="id" data-theme="loketku">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Loketku</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-base-200 flex items-center justify-center p-4 font-sans antialiased">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="inline-block">
          <h1 class="text-4xl font-bold text-primary tracking-tight">Loketku</h1>
        </a>
      </div>
      <slot />
    </div>
  </body>
</html>